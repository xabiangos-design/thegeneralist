---
import SearchInput from "@/components/SearchInput.astro";
import { normalizeText } from "@/lib/normalize";

interface Props {
  categories: string[];
  tags: string[];
}

const { categories, tags } = Astro.props;
---

<section class="bg-white px-4 py-4 md:px-5 md:py-5 lg:px-0" aria-label="Buscar y filtrar libros">
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
    <div class="md:col-span-2">
      <SearchInput />
    </div>
    <label class="block">
      <span class="mb-2 block text-sm font-medium text-stone-700">Categoría</span>
      <select id="category-filter" class="h-11 w-full rounded-md border border-stone-300 bg-white px-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-700/20">
        <option value="">Todas</option>
        {categories.map((category) => <option value={category}>{category}</option>)}
      </select>
    </label>
    <div class="flex items-end justify-start lg:justify-end">
      <button
        id="toggle-tags"
        type="button"
        aria-expanded="false"
        aria-controls="tag-panel"
        class="inline-flex h-11 items-center text-sm font-semibold text-emerald-800 underline-offset-4 transition hover:text-emerald-950 hover:underline"
      >
        Mostrar etiquetas
      </button>
    </div>
  </div>
  <div id="tag-panel" class="mt-4 hidden pt-4">
    <div class="flex gap-2 overflow-x-auto pb-2" role="listbox" aria-label="Etiquetas">
      <button
        type="button"
        data-tag-option=""
        aria-pressed="true"
        class="shrink-0 rounded-full bg-emerald-700 px-3 py-1.5 text-sm font-semibold text-white transition"
      >
        Todas
      </button>
      {
        tags.map((tag) => (
          <button
            type="button"
            data-tag-option={normalizeText(tag)}
            aria-pressed="false"
            class="shrink-0 rounded-full bg-white px-3 py-1.5 text-sm font-semibold text-stone-600 transition hover:text-emerald-800"
          >
            {tag}
          </button>
        ))
      }
    </div>
  </div>
  <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p id="results-count" class="text-sm font-medium text-stone-600" aria-live="polite"></p>
    <button
      id="clear-filters"
      type="button"
      hidden
      class="h-10 items-center justify-center rounded-md bg-white px-4 text-sm font-semibold text-stone-700 shadow-sm transition hover:text-emerald-800"
    >
      Limpiar filtros
    </button>
  </div>
</section>

<script>
  const normalizeText = (value: string) =>
    value
      .toLocaleLowerCase("es")
      .normalize("NFD")
      .replace(/\p{Diacritic}/gu, "")
      .trim();

  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-book-card]"));
  const noResults = document.querySelector<HTMLElement>("#no-results");
  const resultsCount = document.querySelector<HTMLElement>("#results-count");
  const search = document.querySelector<HTMLInputElement>("#book-search");
  const category = document.querySelector<HTMLSelectElement>("#category-filter");
  const tagPanel = document.querySelector<HTMLElement>("#tag-panel");
  const toggleTags = document.querySelector<HTMLButtonElement>("#toggle-tags");
  const tagOptions = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-tag-option]"));
  const clear = document.querySelector<HTMLButtonElement>("#clear-filters");
  let selectedTag = "";

  const setSelectedTag = (value: string) => {
    selectedTag = value;

    tagOptions.forEach((option) => {
      const isActive = option.dataset.tagOption === selectedTag;
      option.setAttribute("aria-pressed", String(isActive));
      option.classList.toggle("bg-emerald-700", isActive);
      option.classList.toggle("text-white", isActive);
      option.classList.toggle("bg-white", !isActive);
      option.classList.toggle("text-stone-600", !isActive);
    });
  };

  const applyFilters = () => {
    const query = normalizeText(search?.value ?? "");
    const selectedCategory = category?.value ?? "";
    const hasActiveFilters = Boolean(query || selectedCategory || selectedTag);
    let visible = 0;

    cards.forEach((card) => {
      const haystack = card.dataset.search ?? "";
      const tags = (card.dataset.tags ?? "").split("|").filter(Boolean);

      const matches =
        (!query || haystack.includes(query)) &&
        (!selectedCategory || card.dataset.category === selectedCategory) &&
        (!selectedTag || tags.includes(selectedTag));

      card.classList.toggle("hidden", !matches);
      if (matches) visible += 1;
    });

    if (resultsCount) {
      resultsCount.textContent = `${visible} ${visible === 1 ? "libro encontrado" : "libros encontrados"}`;
    }
    if (clear) {
      clear.hidden = !hasActiveFilters;
      clear.classList.toggle("inline-flex", hasActiveFilters);
    }
    noResults?.classList.toggle("hidden", visible !== 0);
  };

  [search, category].forEach((control) => {
    control?.addEventListener("input", applyFilters);
    control?.addEventListener("change", applyFilters);
  });

  toggleTags?.addEventListener("click", () => {
    const isHidden = tagPanel?.classList.toggle("hidden");
    const isExpanded = !isHidden;
    toggleTags.setAttribute("aria-expanded", String(isExpanded));
    toggleTags.textContent = isExpanded ? "Ocultar etiquetas" : "Mostrar etiquetas";
  });

  tagOptions.forEach((option) => {
    option.addEventListener("click", () => {
      setSelectedTag(option.dataset.tagOption ?? "");
      applyFilters();
    });
  });

  clear?.addEventListener("click", () => {
    if (search) search.value = "";
    if (category) category.value = "";
    setSelectedTag("");
    applyFilters();
  });

  applyFilters();
</script>
