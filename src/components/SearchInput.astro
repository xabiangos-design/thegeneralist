---
interface Props {
  id?: string;
}

const { id = "book-search" } = Astro.props;
---

<label class="block">
  <span class="mb-2 block text-sm font-medium text-stone-700">Buscar</span>
  <input
    id={id}
    type="search"
    name="search"
    placeholder="Título o autor"
    autocomplete="off"
    class="h-11 w-full rounded-md border border-stone-300 bg-white px-3 text-sm text-stone-900 transition placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-emerald-700/20"
  />
</label>
