---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BookCover from "@/components/BookCover.astro";
import Tag from "@/components/Tag.astro";
import { getBookCoverUrl, getBookSlug } from "@/lib/books";

export async function getStaticPaths() {
  const books = await getCollection("books");

  return books.map((book) => ({
    params: { slug: getBookSlug(book) },
    props: { book }
  }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const data = book.data;
const cover = getBookCoverUrl(data.cover, data.isbn);
const metaItems = [
  ["Categoría", data.category],
  ["Año", data.year],
  ["Páginas", data.pages],
  ["Idioma", data.language],
  ["ISBN", data.isbn]
].filter(([, value]) => value !== undefined && value !== null && value !== "");
---

<BaseLayout title={data.title} description={`Ficha de ${data.title}, de ${data.author}.`}>
  <main class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <a href="/" class="inline-flex items-center text-sm font-semibold text-emerald-800 hover:text-emerald-950">
      ← Volver al listado
    </a>

    <article class="mt-8 grid gap-8 lg:grid-cols-[320px_1fr] lg:gap-12">
      <aside>
        <div class="overflow-hidden rounded-lg border border-stone-200 bg-white shadow-sm">
          <BookCover title={data.title} cover={cover} variant="detail" />
        </div>
      </aside>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-800">{data.category}</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-heading text-stone-950 sm:text-5xl">{data.title}</h1>
        <p class="mt-3 text-xl text-stone-600">{data.author}</p>

        {
          data.featured && (
            <div class="mt-5">
            <span class="rounded-full bg-amber-100 px-3 py-1.5 text-sm font-semibold text-amber-800">
              Destacado
            </span>
            </div>
          )
        }

        <div class="mt-5 flex flex-wrap gap-2">
          {data.tags.map((tag) => <Tag text={tag} />)}
        </div>

        <dl class="mt-8 grid gap-3 sm:grid-cols-2">
          {
            metaItems.map(([label, value]) => (
              <div class="rounded-lg border border-stone-200 bg-white px-4 py-3">
                <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">{label}</dt>
                <dd class="mt-1 text-sm font-medium text-stone-900">{value}</dd>
              </div>
            ))
          }
        </dl>

        <div class="book-content mt-10">
          <Content />
        </div>
      </div>
    </article>
  </main>
</BaseLayout>
