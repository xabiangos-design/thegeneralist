---
import "@/styles/global.css";
import AccessGate from "@/components/AccessGate.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The GeneraList",
  description = "Libros y recursos para diseñadoras/es con intereses varios"
} = Astro.props;
const pageTitle = title === "The GeneraList" ? title : `${title} · The GeneraList`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://covers.openlibrary.org" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-white text-stone-900 antialiased">
    <div class="min-h-screen">
      <AccessGate />
      <div id="private-content" hidden>
        <slot />
      </div>
    </div>
  </body>
</html>
